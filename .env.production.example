PROJECT_NAME=Algo Trading Platform
ENVIRONMENT=production
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<db_host>:5432/<db_name>
REDIS_URL=redis://<redis_host>:6379/0
CELERY_BROKER_URL=redis://<redis_host>:6379/0
CELERY_RESULT_BACKEND=redis://<redis_host>:6379/1

DELTA_API_KEY=<delta_api_key>
DELTA_API_SECRET=<delta_api_secret>
DELTA_BASE_URL=https://api.delta.exchange
DELTA_REQUEST_TIMEOUT_SECONDS=15
DELTA_SYMBOL_TYPE=futures
BROKER_ENCRYPTION_SECRET=<generate-64-plus-char-random-secret>

ZERODHA_API_KEY=<zerodha_api_key>
ZERODHA_API_SECRET=<zerodha_api_secret>

BINANCE_API_KEY=<binance_api_key>
BINANCE_API_SECRET=<binance_api_secret>

JWT_SECRET_KEY=<generate-64-plus-char-random-secret>
JWT_ALGORITHM=HS256
JWT_ISSUER=algo-trading-api
JWT_AUDIENCE=algo-trading-clients
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_HASH_SECRET=<generate-64-plus-char-random-secret>
REFRESH_TOKEN_REUSE_PROTECTION=true
MAX_ACTIVE_SESSIONS_PER_USER=5
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_DURATION_MINUTES=15

OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_PHONE_DEFAULT_COUNTRY_CODE=+91

SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_USERNAME=<smtp_username>
SMTP_PASSWORD=<smtp_password>
SMTP_FROM_EMAIL=no-reply@<your-domain>
SMTP_FROM_NAME=Algo Trading Platform
SMTP_USE_TLS=true
SMTP_USE_SSL=false

TWILIO_ACCOUNT_SID=<twilio_account_sid>
TWILIO_AUTH_TOKEN=<twilio_auth_token>
TWILIO_PHONE_NUMBER=<twilio_sender_phone_e164>

RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_USE_FORWARDED_FOR=true
SECURITY_TRUSTED_PROXIES=["<reverse_proxy_ip>","127.0.0.1","::1"]

MAX_REQUEST_SIZE_BYTES=1048576
ENABLE_SECURITY_HEADERS=true
HSTS_MAX_AGE_SECONDS=31536000

CORS_ORIGINS=["https://<your-frontend-domain>"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-Id"]

ADMIN_SEED_EMAIL=<admin_email>
ADMIN_SEED_PASSWORD=<strong-admin-password>
ADMIN_SEED_FULL_NAME=Super Admin
