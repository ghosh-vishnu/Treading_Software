PROJECT_NAME=Algo Trading Platform
ENVIRONMENT=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/algo_trading
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

DELTA_API_KEY=
DELTA_API_SECRET=
DELTA_BASE_URL=https://api.delta.exchange
DELTA_REQUEST_TIMEOUT_SECONDS=15
DELTA_SYMBOL_TYPE=futures
BROKER_ENCRYPTION_SECRET=replace-with-a-long-random-broker-secret

ZERODHA_API_KEY=
ZERODHA_API_SECRET=

BINANCE_API_KEY=
BINANCE_API_SECRET=

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=algo-trading-api
JWT_AUDIENCE=algo-trading-clients
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_HASH_SECRET=replace-with-another-long-random-secret
REFRESH_TOKEN_REUSE_PROTECTION=true
MAX_ACTIVE_SESSIONS_PER_USER=5
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_DURATION_MINUTES=15
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_PHONE_DEFAULT_COUNTRY_CODE=+91

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Algo Trading Platform
SMTP_USE_TLS=true
SMTP_USE_SSL=false

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_USE_FORWARDED_FOR=true
SECURITY_TRUSTED_PROXIES=["127.0.0.1","::1"]

MAX_REQUEST_SIZE_BYTES=1048576
ENABLE_SECURITY_HEADERS=true
HSTS_MAX_AGE_SECONDS=31536000

CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
# Keep these tight in production; avoid "*" to reduce attack surface.
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-Id"]

ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe@12345
ADMIN_SEED_FULL_NAME=Super Admin
